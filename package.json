{
	"name": "d4c-monorepo",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"clean": "npm run clean --workspaces",
		"build": "cd packages/tui && npm run build && cd ../agent && npm run build && cd ../coding-agent && npm run build",
		"check": "biome check --write --error-on-warnings . && tsgo --noEmit",
		"test": "npm run test --workspaces --if-present"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/node": "22.19.19",
		"@typescript/native-preview": "7.0.0-dev.20260120.1",
		"esbuild": "0.28.0",
		"jiti": "2.7.0",
		"shx": "0.4.0",
		"tsx": "4.22.1",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"version": "0.1.0",
	"overrides": {
		"rimraf": "6.1.2",
		"gaxios": {
			"rimraf": "6.1.2"
		}
	},
	"dependencies": {
		"@aws-sdk/client-bedrock-runtime": "^3.1069.0",
		"@google/genai": "^2.8.0",
		"@mistralai/mistralai": "^2.2.5",
		"@smithy/node-http-handler": "^4.8.0",
		"@smithy/types": "^4.15.0",
		"get-east-asian-width": "^1.6.0",
		"http-proxy-agent": "^9.1.0",
		"https-proxy-agent": "^9.1.0",
		"marked": "^18.0.5",
		"openai": "^6.42.0",
		"partial-json": "^0.1.7"
	}
}
