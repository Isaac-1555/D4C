{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"paths": {
			"d4c-agent-core": ["../agent/dist/index.d.ts"],
			"d4c-agent-core/*": ["../agent/dist/*.d.ts"],
			"d4c-ai": ["../ai/dist/index.d.ts"],
			"d4c-ai/*": ["../ai/dist/*.d.ts", "../ai/dist/providers/*.d.ts"],
			"d4c-tui": ["../tui/dist/index.d.ts"],
			"d4c-tui/*": ["../tui/dist/*.d.ts", "../tui/dist/components/*.d.ts"]
		},
		"rootDir": "./src"
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts"],
	"exclude": ["node_modules", "dist"]
}
