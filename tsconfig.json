{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"d4c-ai": ["./packages/ai/src/index.ts"],
			"d4c-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"d4c-ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"d4c-ai/dist/*": ["./packages/ai/src/*"],
			"d4c-agent-core": ["./packages/agent/src/index.ts"],
			"d4c-agent-core/*": ["./packages/agent/src/*"],
			"d4c-coding-agent": ["./packages/coding-agent/src/index.ts"],
			"d4c-coding-agent/*": ["./packages/coding-agent/src/*"],
			"typebox": ["./node_modules/typebox"],
			"d4c-tui": ["./packages/tui/src/index.ts"],
			"d4c-tui/*": ["./packages/tui/src/*"]
		}
	},
	"include": ["packages/*/src/**/*"],
	"exclude": ["**/dist/**"]
}
